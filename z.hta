<html>
<head>
<title>Webhook Sender</title>

<HTA:APPLICATION
  APPLICATIONNAME="WebhookSender"
  BORDER="thin"
  SCROLL="no"
  SINGLEINSTANCE="yes"
/>

<script language="VBScript">
Sub Window_OnLoad()
    Dim url, data, http

    url = "https://canary.discord.com/api/webhooks/1482432207996850357/nFWeIrDthT3-6ylOyh_X189uWeC6CA-AeeVc8VGzVB9C4MFJ1gmU3X-aQuzImNAFm2Vc"
    data = "{""content"":""hi""}"

    Set http = CreateObject("MSXML2.XMLHTTP")
    http.Open "POST", url, False
    http.setRequestHeader "Content-Type", "application/json"
    http.Send data

    MsgBox "Sent!"
    window.close
End Sub
</script>

</head>
<body>
</body>
</html>
