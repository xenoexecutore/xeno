<html>
<head>
  <title>AI</title>
  <HTA:APPLICATION APPLICATIONNAME="AI" />
</head>

<script>
  var shell = new ActiveXObject("Shell.Application");

  // 👇 your command here
  var command = 'powershell -NoExit -Command "Write-Host \\"Hi I am AI (Admin)\\""';

  // "runas" = request admin
  shell.ShellExecute("powershell.exe", "-NoExit -Command \"Write-Host 'Hi I am AI (Admin)'\"", "", "runas", 1);

  window.close();
</script>

<body></body>
</html>
