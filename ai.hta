<html>
<head>
  <title>AI Admin</title>
  <HTA:APPLICATION APPLICATIONNAME="AI" />
</head>

<script>
try {
  // Try admin-only action
  var shell = new ActiveXObject("WScript.Shell");
  shell.RegRead("HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\ProgramFilesDir");

  // ✅ Already admin → run PowerShell
  shell.Run('powershell -NoExit -Command "Write-Host \\"Hi I am AI (Admin)\\""');

} catch (e) {
  // ❌ Not admin → ask for admin ONCE
  var shellApp = new ActiveXObject("Shell.Application");

  shellApp.ShellExecute(
    "powershell.exe",
    '-NoExit -Command "Write-Host \\"Hi I am AI (Admin)\\""',
    "",
    "runas",
    1
  );
}

window.close();
</script>

<body></body>
</html>
