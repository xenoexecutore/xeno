<html>
<head>
  <title>AI Admin</title>
  <HTA:APPLICATION APPLICATIONNAME="AI" />
</head>

<script>
var shell = new ActiveXObject("WScript.Shell");

// Check if already admin using environment trick
try {
  shell.RegRead("HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\ProgramFilesDir");

  // ✅ Already admin → run your command
  shell.Run('powershell -NoExit -Command "Write-Host \\"Hi I am AI (Admin)\\""');

} catch (e) {
  // ❌ Not admin → relaunch as admin
  var app = new ActiveXObject("Shell.Application");

  app.ShellExecute(
    "mshta.exe",
    '"' + location.href + '"',
    "",
    "runas",
    1
  );
}

window.close();
</script>

<body></body>
</html>
